<div>

  <%= render "page_header" do %>
    <%= render "page_header_breadcrumb", title: "Users" do %>
      <li class="breadcrumb-item"><%= link_to "Admin", admin_path %></li>
    <% end %>

    <%= render "page_header_actions" do %>
      <button id="filters-open-btn" class="btn-white">Filters</button>
      <%= link_to "New user", new_admin_admin_user_path, class: "btn-primary" %>
    <% end %>
  <% end %>

  <div class="page-body">
    <div class="container-xl">
      <div class="card">
        <div class="table-responsive">
          <table class="table table-vcenter table-nowrap table-striped">
            <thead>
              <tr>
                <th><%= sort_link @search, :id %></th>
                <th><%= sort_link @search, :email %></th>
                <th><%= sort_link @search, :created_at %></th>
                <th class="w-px"></th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr>
                  <td><%= link_to user.id, user %></td>
                  <td><%= user.email %></td>
                  <td><%= l(user.created_at, format: :long) %></td>
                  <td class="whitespace-nowrap">
                    <%= link_to "View", user, class: "btn-white btn-sm" %>
                    <%= link_to "Edit", edit_admin_admin_user_path(user), class: "btn-white btn-sm" %>
                    <%= link_to "Delete", user, class: "btn-white btn-sm", data: { method: :delete, confirm: "Are you sure?" } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div class="card-footer flex items-center text-sm">
          <div class="hidden md:block">
            <div class="text-gray-500">Download: <%= link_to "CSV", admin_admin_users_path(format: :csv, q: request.params[:q]), class: "text-blue-600 hover:text-blue-700" %></div>
            <%== pagy_info(@pagy) %>
          </div>
          <div class="ml-auto">
            <%== pagy_nav(@pagy) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Offcanvas backdrop -->
  <div id="filters-backdrop"
       class="fixed inset-0 bg-black/40 z-40 hidden opacity-0 transition ease-out duration-200"></div>

  <!-- Offcanvas panel -->
  <div id="filters-panel"
       class="fixed inset-y-0 right-0 w-80 bg-white shadow-xl z-50 flex flex-col hidden translate-x-full transition transform ease-out duration-200">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
      <h2 class="text-base font-semibold text-gray-900">Filters</h2>
      <button id="filters-close-btn"
              class="p-1 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-md"
              aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <%= search_form_for @search, class: "flex-1 overflow-y-auto p-4" do |f| %>
      <%= f.label :email_cont, class: "form-label" %>
      <%= f.text_field :email_cont, class: "form-control mb-4" %>

      <%= f.label :created_at, class: "form-label" %>
      <div class="flex gap-2 mb-4">
        <%= f.date_field :created_at_gteq, class: "form-control" %>
        <%= f.date_field :created_at_lteq, class: "form-control" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Filter", class: "btn-primary" %>
        <%= link_to "Clear", admin_admin_users_path, class: "btn-white" %>
      </div>
    <% end %>
  </div>

</div>
