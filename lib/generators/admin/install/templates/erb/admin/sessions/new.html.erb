<div class="bg-white rounded-xl shadow-sm border border-gray-200 w-full">
  <div class="p-6">
    <h1 class="text-xl font-semibold text-gray-900 dark:text-white  text-center mb-6">Login to your account</h1>
    <%= form_with(url: admin_sign_in_path) do |form| %>
      <div class="mb-4">
        <%= form.label :email, class: "form-label" %>
        <%= form.email_field :email, value: params[:email_hint], placeholder: "Enter email",
              autofocus: true, required: true, autocomplete: "email", class: "form-control" %>
      </div>
      <div class="mb-5">
        <div class="flex items-center justify-between mb-1">
          <%= form.label :password, class: "form-label !mb-0" %>
          <%= link_to "Forgot password?", new_admin_password_reset_path, class: "text-sm text-blue-600 hover:text-blue-700" %>
        </div>
        <%= form.password_field :password, placeholder: "Password", required: true,
              autocomplete: "current-password", class: "form-control" %>
      </div>
      <%= form.submit "Sign in", class: "btn-primary w-full justify-center" %>
    <% end %>
  </div>
</div>
