

<!-- Apply dark mode immediately to avoid flash -->
<script>document.documentElement.classList.toggle('dark', localStorage.getItem('darkMode') === 'true')</script>

<script>
  document.addEventListener('turbo:load', function() {
    // Dark mode
    const darkMode = {
      on: localStorage.getItem('darkMode') === 'true',
      toggle() {
        this.on = !this.on
        localStorage.setItem('darkMode', String(this.on))
        document.documentElement.classList.toggle('dark', this.on)
        syncDarkIcons()
      }
    }

    function syncDarkIcons() {
      document.getElementById('dark-mode-moon')?.classList.toggle('hidden', darkMode.on)
      document.getElementById('dark-mode-sun')?.classList.toggle('hidden', !darkMode.on)
    }
    syncDarkIcons()

    document.getElementById('dark-mode-btn')?.addEventListener('click', () => darkMode.toggle())

    // Mobile menu
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('toggle-mobile-menu'))
    })

    const secondaryNav = document.getElementById('secondary-nav')
    if (secondaryNav) {
      window.addEventListener('toggle-mobile-menu', () => {
        secondaryNav.classList.toggle('hidden')
        secondaryNav.classList.toggle('flex')
      })
    }

    // Dropdowns
    function initDropdown(btnId, panelId) {
      const btn = document.getElementById(btnId)
      const panel = document.getElementById(panelId)
      if (!btn || !panel) return

      function openPanel() {
        panel.classList.remove('hidden')
        requestAnimationFrame(() => {
          panel.classList.remove('opacity-0', 'scale-95')
          panel.classList.add('opacity-100', 'scale-100')
        })
      }

      function closePanel() {
        panel.classList.remove('opacity-100', 'scale-100')
        panel.classList.add('opacity-0', 'scale-95')
        panel.addEventListener('transitionend', () => panel.classList.add('hidden'), { once: true })
      }

      btn.addEventListener('click', (e) => {
        e.stopPropagation()
        panel.classList.contains('hidden') ? openPanel() : closePanel()
      })

      document.addEventListener('click', () => {
        if (!panel.classList.contains('hidden')) closePanel()
      })
    }

    initDropdown('notifications-btn', 'notifications-panel')
    initDropdown('user-menu-btn', 'user-menu-panel')

    // Offcanvas — auto-discovers via data-offcanvas-open/panel/backdrop/close attributes
    document.querySelectorAll('[data-offcanvas-open]').forEach(openBtn => {
      const name = openBtn.dataset.offcanvasOpen
      const panel = document.querySelector(`[data-offcanvas-panel="${name}"]`)
      const backdrop = document.querySelector(`[data-offcanvas-backdrop="${name}"]`)
      const closeBtn = panel?.querySelector('[data-offcanvas-close]')
      if (!panel || !backdrop || !closeBtn) return

      function open() {
        backdrop.classList.remove('hidden')
        panel.classList.remove('hidden')
        requestAnimationFrame(() => {
          backdrop.classList.add('opacity-100')
          panel.classList.remove('translate-x-full')
        })
      }

      function close() {
        backdrop.classList.remove('opacity-100')
        panel.classList.add('translate-x-full')
        panel.addEventListener('transitionend', () => {
          backdrop.classList.add('hidden')
          panel.classList.add('hidden')
        }, { once: true })
      }

      openBtn.addEventListener('click', open)
      closeBtn.addEventListener('click', close)
      backdrop.addEventListener('click', close)
    })
})
</script>

<% if content_for?(:javascript_files) %>
  <%= yield(:javascript_files) %>
<% end %>