<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 print:hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center h-14 gap-3">

      <!-- Mobile hamburger (toggles secondary navbar) -->
      <button id="mobile-menu-btn"
              class="md:hidden p-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md"
              aria-label="Toggle navigation">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <!-- Logo -->
      <div class="flex-shrink-0">
        <%= link_to admin_path do %>
          <%= image_tag "admin/logo.svg", width: 110, height: 32, alt: "Admin", class: "block" %>
        <% end %>
      </div>

      <!-- Right-side items -->
      <div class="ml-auto flex items-center gap-1">


        <!-- Dark mode toggle -->
        <button id="dark-mode-btn"
                class="p-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors"
                aria-label="Toggle dark mode">
          <svg id="dark-mode-moon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"/>
          </svg>
          <svg id="dark-mode-sun" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <circle cx="12" cy="12" r="4"/>
            <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"/>
          </svg>
        </button>

        <!-- Notifications -->
        <div class="relative hidden md:block">
          <button id="notifications-btn"
                  class="relative p-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors"
                  aria-label="Show notifications">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 5a2 2 0 0 1 4 0a7 7 0 0 1 4 6v3a4 4 0 0 0 2 3h-16a4 4 0 0 0 2 -3v-3a7 7 0 0 1 4 -6" /><path d="M9 17v1a3 3 0 0 0 6 0v-1" /></svg>
            <span class="absolute top-0.5 right-0.5 h-2 w-2 rounded-full bg-red-500"></span>
          </button>
          <div id="notifications-panel"
               class="absolute right-0 mt-2 w-72 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 z-50 overflow-hidden hidden opacity-0 scale-95 transition ease-out duration-100 origin-top-right">
            <div class="p-4 text-sm text-gray-600 dark:text-gray-400">
              No notifications yet.
            </div>
          </div>
        </div>

        <!-- User menu -->
        <div class="relative">
          <button id="user-menu-btn"
                  class="flex items-center gap-2 pl-1 pr-2 py-1 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                  aria-label="Open user menu">
            <span class="h-8 w-8 rounded-full bg-cover bg-center flex-shrink-0 bg-gray-200 dark:bg-gray-700"
                  style="background-image: url(<%= asset_path "admin/000m.jpg" %>)"></span>
            <div class="hidden xl:block text-left leading-tight">
              <div class="text-sm font-medium text-gray-900 dark:text-gray-50">Administrator</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Admin panel</div>
            </div>
          </button>
          <div id="user-menu-panel"
               class="absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 py-1 z-50 hidden opacity-0 scale-95 transition ease-out duration-100 origin-top-right">
            <a href="#" class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">Profile &amp; account</a>
            <a href="#" class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">Settings</a>
            <div class="border-t border-gray-100 dark:border-gray-700 my-1"></div>
            <%= button_to "Logout", admin_sign_out_path, method: :delete,
                  form: { class: "block" },
                  class: "block w-full text-left px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 bg-transparent border-0 cursor-pointer" %>
          </div>
        </div>

      </div>
    </div>
  </div>
</header>
