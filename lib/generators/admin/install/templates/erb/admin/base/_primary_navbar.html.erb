<header class="bg-white border-b border-gray-200 print:hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center h-14 gap-3">

      <!-- Mobile hamburger (toggles secondary navbar) -->
      <button id="mobile-menu-btn"
              class="md:hidden p-1.5 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-md"
              aria-label="Toggle navigation">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <!-- Logo -->
      <div class="flex-shrink-0">
        <%= link_to admin_path do %>
          <%= image_tag "admin/logo.svg", width: 110, height: 32, alt: "Admin", class: "block" %>
        <% end %>
      </div>

      <!-- Right-side items -->
      <div class="ml-auto flex items-center gap-1">

        <!-- Desktop external links -->
        <div class="hidden md:flex items-center gap-1 mr-2">
          <a href="https://github.com/lazaronixon/administration-zero" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-md border border-gray-200 transition-colors" target="_blank" rel="noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>
            Source code
          </a>
          <a href="https://github.com/sponsors/lazaronixon" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-md border border-gray-200 transition-colors" target="_blank" rel="noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-pink-500" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M19.5 13.572l-7.5 7.428l-7.5 -7.428m0 0a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572" /></svg>
            Sponsor
          </a>
        </div>

        <!-- Dark mode toggle -->
        <button id="dark-mode-btn"
                class="p-1.5 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-md transition-colors"
                title="Toggle dark mode">
          <svg id="dark-mode-moon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" /></svg>
          <svg id="dark-mode-sun" class="hidden h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4" /><path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" /></svg>
        </button>

        <!-- Notifications -->
        <div class="relative hidden md:block">
          <button id="notifications-btn"
                  class="relative p-1.5 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-md transition-colors"
                  aria-label="Show notifications">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 5a2 2 0 0 1 4 0a7 7 0 0 1 4 6v3a4 4 0 0 0 2 3h-16a4 4 0 0 0 2 -3v-3a7 7 0 0 1 4 -6" /><path d="M9 17v1a3 3 0 0 0 6 0v-1" /></svg>
            <span class="absolute top-0.5 right-0.5 h-2 w-2 rounded-full bg-red-500"></span>
          </button>
          <div id="notifications-panel"
               class="absolute right-0 mt-2 w-72 bg-white rounded-lg shadow-lg border border-gray-200 z-50 overflow-hidden hidden opacity-0 scale-95 transition ease-out duration-100 origin-top-right">
            <div class="p-4 text-sm text-gray-600">
              No notifications yet.
            </div>
          </div>
        </div>

        <!-- User menu -->
        <div class="relative">
          <button id="user-menu-btn"
                  class="flex items-center gap-2 pl-1 pr-2 py-1 rounded-md hover:bg-gray-100 transition-colors"
                  aria-label="Open user menu">
            <span class="h-8 w-8 rounded-full bg-cover bg-center flex-shrink-0 bg-gray-200"
                  style="background-image: url(<%= asset_path "admin/000m.jpg" %>)"></span>
            <div class="hidden xl:block text-left leading-tight">
              <div class="text-sm font-medium text-gray-900">Administrator</div>
              <div class="text-xs text-gray-500">Admin panel</div>
            </div>
          </button>
          <div id="user-menu-panel"
               class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50 hidden opacity-0 scale-95 transition ease-out duration-100 origin-top-right">
            <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Profile &amp; account</a>
            <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Settings</a>
            <div class="border-t border-gray-100 my-1"></div>
            <%= button_to "Logout", admin_sign_out_path, method: :delete,
                  form: { class: "block" },
                  class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 bg-transparent border-0 cursor-pointer" %>
          </div>
        </div>

      </div>
    </div>
  </div>
</header>
