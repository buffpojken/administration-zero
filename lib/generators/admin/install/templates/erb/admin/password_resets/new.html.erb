<div class="bg-white rounded-xl shadow-sm border border-gray-200 w-full">
  <div class="p-6">
    <h1 class="text-xl font-semibold text-gray-900 text-center mb-2">Forgot password</h1>
    <p class="text-sm text-gray-500 text-center mb-6">Enter your email address and your password will be reset and emailed to you.</p>
    <%= form_with(url: admin_password_reset_path) do |form| %>
      <div class="mb-5">
        <%= form.label :email, class: "form-label" %>
        <%= form.email_field :email, placeholder: "Enter email", autofocus: true, required: true, class: "form-control" %>
      </div>
      <%= form.submit "Send me new password", class: "btn-primary w-full justify-center" %>
    <% end %>
  </div>
</div>

<p class="text-center text-sm text-gray-500 mt-4">
  Forget it, <%= link_to "send me back", admin_sign_in_path, class: "text-blue-600 hover:text-blue-700" %> to the sign in screen.
</p>
