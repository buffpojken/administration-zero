<div class="bg-white rounded-xl shadow-sm border border-gray-200 w-full">
  <div class="p-6">
    <h1 class="text-xl font-semibold text-gray-900 text-center mb-6">Reset password</h1>
    <%= form_with(url: admin_password_reset_path, method: :patch) do |form| %>
      <%= hidden_field_tag :token, params[:token] %>

      <div class="mb-4">
        <%= form.label :password, "New password", class: "form-label" %>
        <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password", class: "form-control" %>
      </div>

      <div class="mb-5">
        <%= form.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "form-control" %>
      </div>

      <%= form.submit "Save changes", class: "btn-primary w-full justify-center" %>
    <% end %>
  </div>
</div>
